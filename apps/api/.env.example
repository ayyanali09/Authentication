NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/vantanova
JWT_SECRET=replace-with-a-unique-64-character-production-secret-generated-by-crypto
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
BOOTSTRAP_ADMIN_ON_START=true
SEED_ADMIN_NAME=DURON Admin
SEED_ADMIN_EMAIL=replace-with-admin-email@example.com
SEED_ADMIN_PASSWORD=replace-with-a-strong-admin-password-before-production

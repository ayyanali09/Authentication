# Optional if you already ran: npx.cmd --yes vercel@latest login
# VERCEL_TOKEN=replace-with-vercel-token
# Optional: set if your Vercel project belongs to a team instead of your personal account.
# VERCEL_TEAM=replace-with-team-slug-or-id
VERCEL_PROJECT=site-1

HOSTINGER_API_TOKEN=replace-with-hostinger-api-token
# Override only if Vercel shows a different CNAME target for www.
# VERCEL_WWW_CNAME=cname.vercel-dns-0.com
